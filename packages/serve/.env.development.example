# 开发环境配置（复制为 .env.development）
PORT=3000

# MySQL 数据库连接
DATABASE_URL="mysql://user:password@localhost:3306/xiaomaque"

# JWT 密钥
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# OpenAI API（LangChain 使用）
OPENAI_API_KEY=your-openai-api-key


# 允许跨域的前端地址，多个用英文逗号分隔
CORS_ORIGIN=http://localhost:12345

# API 请求签名密钥（需与前端 VITE_API_SIGN_SECRET 保持一致）
API_SIGN_SECRET=your-api-sign-secret

# 火山方舟 Seedream 图片生成（https://console.volcengine.com/ark/region:ark+cn-beijing/apikey）
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_MODEL_5_0=doubao-seedream-5-0-260128
SEEDREAM_MODEL_4_5=doubao-seedream-4-5-251128
SEEDANCE_MODEL_2_0=doubao-seedance-2-0-260128
SEEDANCE_MODEL_2_0_FAST=doubao-seedance-2-0-fast-260128

# 七牛云对象存储（https://portal.qiniu.com/）
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET=your-qiniu-bucket
QINIU_CDN_BASE_URL=your-qiniu-cdn-base-url